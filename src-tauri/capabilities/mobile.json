{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-capability",
  "description": "Android/iOS webview IPC and dev-server remote access",
  "windows": ["main"],
  "webviews": ["main"],
  "platforms": ["android", "iOS"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "http://10.0.2.2:*",
      "http://192.168.*:*",
      "http://tauri.localhost/*"
    ]
  },
  "permissions": ["core:default", "core:event:default", "opener:default", "shell:default"]
}
